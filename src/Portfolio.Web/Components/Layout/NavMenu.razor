            <a class="nav-link" href="#articles">Articles</a>
            <a class="nav-link nav-link-highlight" href="#contact">Contact</a>
        </div>
    </div>
</nav>

@code {
    private bool _menuOpen;

    private string GetMenuClass() => _menuOpen ? "open" : "";

    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }

    private void CloseMenu()
    {
        _menuOpen = false;
    }
}
