@page "/"
@layout MainLayout
@inject IJSRuntime JSRuntime

<HeroSection />
<AboutSection />
<SkillsSection />
<ExperienceSection />
<ProjectsSection />
<SignatureProjectSection />
<GithubSection />
<ArticlesSection />
<ContactSection />

@code {
    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await JSRuntime.InvokeVoidAsync("initPortfolio");
        }
    }
}
