<section class="signature-section section" id="signature">
    <div class="container">
        <div class="section-header">
            <RadzenBadge Variant="Variant.Flat" class="section-label">Signature Project</RadzenBadge>
            <h2 class="section-title">Legacy Modernization <span class="gradient-text">Accelerator</span></h2>
            <p class="section-subtitle">A complete modernization framework for migrating enterprise .NET Framework applications to .NET 9.</p>
            <div class="section-divider"></div>
        </div>

        <div class="signature-intro">
            <p style="color: var(--text-secondary); max-width: 700px; margin: 0 auto; line-height: 1.8;">
                The <strong>Legacy Modernization Accelerator</strong> is a comprehensive migration framework
                designed to transform monolithic .NET Framework applications into modern, scalable, cloud-ready
                architectures. The repository includes side-by-side legacy and modern implementations so recruiters can see the engineering judgment behind the migration, not just the final result.
            </p>
        </div>

        <div class="signature-content">

            <div class="signature-comparison">
                <RadzenCard Variant="Variant.Flat" class="comparison-block before">
                    <div class="comparison-label before-label">
                        <span class="arrow-icon">&#8595;</span> Before: Legacy Stack
                    </div>
                    <ul class="comparison-items">
                        <li>.NET Framework 4.x</li>
                        <li>Monolithic Architecture</li>
                        <li>Synchronous Processing</li>
                        <li>Tight Coupling</li>
                        <li>XML Configurations</li>
                        <li>Windows-only Deployment</li>
                        <li>Manual Deployments</li>
                    </ul>
                </RadzenCard>

                <RadzenCard Variant="Variant.Flat" class="comparison-block after">
                    <div class="comparison-label after-label">
                        <span class="arrow-icon">&#8595;</span> After: Modern Stack
                    </div>
                    <ul class="comparison-items">
                        <li>.NET 9</li>
                        <li>Clean Architecture</li>
                        <li>CQRS with MediatR</li>
                        <li>Async/Await Processing</li>
                        <li>JWT Authentication</li>
                        <li>Docker & Container Support</li>
                        <li>CI/CD Pipeline</li>
                    </ul>
                </RadzenCard>
            </div>

            <RadzenCard Variant="Variant.Flat" class="migration-flow">
                <div class="migration-flow-title">Migration Architecture Flow</div>
                <div class="migration-steps">
                    <div class="migration-step">
                        <div class="migration-step-icon remove">&#10005;</div>
                        <div class="migration-step-dot remove"></div>
                        <span class="migration-step-text">Monolithic .NET Framework 4.x</span>
                    </div>
                    <div class="migration-step">
                        <div class="migration-step-icon transform">&#8595;</div>
                        <div class="migration-step-dot transform"></div>
                        <span class="migration-step-text">Domain Analysis & Boundary Identification</span>
                    </div>
                    <div class="migration-step">
                        <div class="migration-step-icon transform">&#8595;</div>
                        <div class="migration-step-dot transform"></div>
                        <span class="migration-step-text">Clean Architecture Layering (Core, Infrastructure, Presentation)</span>
                    </div>
                    <div class="migration-step">
                        <div class="migration-step-icon transform">&#8595;</div>
                        <div class="migration-step-dot transform"></div>
                        <span class="migration-step-text">CQRS with MediatR Pipelines</span>
                    </div>
                    <div class="migration-step">
                        <div class="migration-step-icon transform">&#8595;</div>
                        <div class="migration-step-dot transform"></div>
                        <span class="migration-step-text">Async Processing & JWT Security</span>
                    </div>
                    <div class="migration-step">
                        <div class="migration-step-icon add">&#10003;</div>
                        <div class="migration-step-dot add"></div>
                        <span class="migration-step-text">Docker Containers & CI/CD Deployment</span>
                    </div>
                </div>
            </RadzenCard>

        </div>
    </div>
</section>

